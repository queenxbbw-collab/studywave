# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/studywave

# Secret for JWT signing (generate a random string, min 32 chars)
SESSION_SECRET=change-this-to-a-long-random-secret-string

# Port the server listens on
PORT=3000

# (Optional) Path to built frontend — leave empty to use default
# STATIC_PATH=/absolute/path/to/artifacts/studywave/dist/public
